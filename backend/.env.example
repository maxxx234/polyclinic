# ---- Database ----
# MongoDB connection string. Leave empty ONLY for local dev (spins up an
# in-memory MongoDB). Production MUST set a real Atlas/Mongo URL.
MONGODB_URI="mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/polyclinic?retryWrites=true&w=majority"

# ---- Auth ----
JWT_SECRET="replace-with-a-long-random-string"
JWT_EXPIRES_IN="7d"

# ---- Server ----
# Host usually injects PORT automatically; safe to omit in production.
PORT=4000
# Comma-separated allowed frontend origins (CORS).
CLIENT_ORIGIN="http://localhost:5173,https://your-frontend.vercel.app"

# ---- AI / LLM (server-side only; never exposed to the browser) ----
LLM_ENDPOINT="https://menu.soyagora.com/api/v4/llm/stream"
LLM_TOKEN="your-llm-token"

# ---- Seed admin account (used when seeding an empty database) ----
SEED_ADMIN_EMAIL="admin@yourclinic.com"
SEED_ADMIN_PASSWORD="a-strong-admin-password"
